[sqlfluff]
dialect = postgres
templater = jinja
sql_file_exts = .sql,.psql,.sql.j2,.dml,.ddl
rules = core
exclude_rules = LT01, L031, L034, PRS
max_line_length = 150
large_file_skip_byte_limit = 30000
 
[sqlfluff:indentation]
indented_joins = False
indented_ctes = False
indented_using_on = True
indented_on_contents = False
template_blocks_indent = True
tab_space_size = 4
