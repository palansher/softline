{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder:32b-instruct-q3_K_L",
  "provider": {
    "ollama": {
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:32b-instruct-q3_K_L": {
          "name": "Qwen 2.5 Coder 32B Q3_K_L",
          "limit": {
            "context": 16384,
            "output": 4096
          },
          "options": {
            "temperature": 0.1
          }
        }
      }
    }
  }
}
